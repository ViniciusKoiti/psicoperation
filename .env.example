# =============================================================================
# PsiOps — variáveis de ambiente do desenvolvimento local (PSI-003)
#
# Copie este arquivo para .env (gitignorado) e ajuste conforme necessário.
# Todos os valores abaixo são os defaults já embutidos no docker-compose.yml:
# sem .env, "docker compose up -d" funciona do mesmo jeito.
# =============================================================================

# --- PostgreSQL 16 (banco único: tabelas JPA + event store do Axon) ----------

# Host do PostgreSQL visto pelas aplicações rodando FORA do Docker
# (apps/api etc.). Não é usado pelo compose em si.
POSTGRES_HOST=localhost

# Porta exposta no host (mapeia para 5432 dentro do container).
# Mude se já houver um PostgreSQL local ocupando 5432.
POSTGRES_PORT=5432

# Usuário do banco (superusuário criado pela imagem oficial).
POSTGRES_USER=psiops

# Senha do usuário. Valor apenas para desenvolvimento local — nunca use
# este default fora da sua máquina.
POSTGRES_PASSWORD=psiops

# Nome do database criado na inicialização.
POSTGRES_DB=psiops

# --- Mailpit (captura de e-mails em desenvolvimento) --------------------------

# Host do Mailpit visto pelas aplicações rodando fora do Docker.
# Não é usado pelo compose em si.
MAILPIT_HOST=localhost

# Porta SMTP exposta no host (as aplicações enviam e-mail para cá).
MAILPIT_SMTP_PORT=1025

# Porta da UI web exposta no host (http://localhost:8025 para inspecionar
# os e-mails capturados).
MAILPIT_UI_PORT=8025
