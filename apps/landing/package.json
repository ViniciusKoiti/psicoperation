{
  "name": "@psiops/landing",
  "version": "0.1.0",
  "private": true,
  "description": "Landing page pública do PsiOps (Next.js App Router + Tailwind com tokens de @psiops/ui). Scaffold da PSI-009; seções reais da página chegam na PSI-019.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "prettier": "@psiops/config/prettier",
  "dependencies": {
    "@psiops/ui": "workspace:*",
    "next": "^16.2.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@psiops/config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.30.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "prettier": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22"
  }
