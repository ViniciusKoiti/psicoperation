{
  "name": "@psiops/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Especificação OpenAPI 3.1 do PsiOps (fonte única de contratos, ADR 0008) + codegen TypeScript comitado em gen/ts. Consumido via workspace:* — tipos puros, sem etapa de build. Codegen Java/Dart chega na PSI-006.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./gen/ts/index.d.ts"
    },
    "./api": {
      "types": "./gen/ts/api.d.ts"
    },
    "./openapi/openapi.yaml": "./openapi/openapi.yaml"
  },
  "scripts": {
    "lint": "eslint . && redocly lint",
    "lint:spec": "redocly lint",
    "generate": "node scripts/generate.mjs",
    "check:drift": "node scripts/generate.mjs && git diff --exit-code -- gen",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "prettier": "@psiops/config/prettier",
  "devDependencies": {
    "@psiops/config": "workspace:*",
    "@redocly/cli": "2.37.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.30.0",
    "openapi-typescript": "7.13.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=22"
  }
}
