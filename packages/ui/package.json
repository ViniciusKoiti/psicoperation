{
  "name": "@psiops/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Design system do PsiOps: tokens (CSS vars, TS, tema Mantine, preset Tailwind, tokens.json para o tema Flutter) e primitivas React (Button, Card, Pill). Fonte única em src/tokens; artefatos gerados com drift bloqueado por teste.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "default": "./dist/tokens/index.js"
    },
    "./mantine": {
      "types": "./dist/mantine/index.d.ts",
      "default": "./dist/mantine/index.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "default": "./dist/tailwind/index.js"
    },
    "./tokens.json": "./tokens.json",
    "./tokens.css": "./css/tokens.css",
    "./components.css": "./css/components.css",
    "./styles.css": "./css/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "pnpm build && node scripts/generate-artifacts.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "prettier": "@psiops/config/prettier",
  "peerDependencies": {
    "@mantine/core": "^8.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@mantine/core": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mantine/core": "^8.1.0",
    "@mantine/hooks": "^8.1.0",
    "@psiops/config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.30.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22"
  }
}
