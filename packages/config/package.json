{
  "name": "@psiops/config",
  "version": "0.1.0",
  "private": true,
  "description": "Configurações compartilhadas de tooling JS/TS do monorepo PsiOps: tsconfig base, preset ESLint (flat config), Prettier e preset Vitest. Consumido via workspace:* — sem etapa de build.",
  "type": "module",
  "exports": {
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/react.json": "./tsconfig/react.json",
    "./eslint": "./eslint/index.js",
    "./prettier": "./prettier/index.js",
    "./vitest": "./vitest/index.js"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "prettier": "@psiops/config/prettier",
  "dependencies": {
    "@eslint/js": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript-eslint": "^8.35.0"
  },
  "devDependencies": {
    "eslint": "^9.30.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": ">=9.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.5.0",
    "vitest": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@vitest/coverage-v8": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "prettier": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
